<Window x:Class="drawing_app.ImportBrushWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Import New Brush"
        Height="450"
        Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="16">

        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

   
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>  
                <ColumnDefinition Width="1.8*"/>  
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,15,0">

                <StackPanel>
                    <TextBlock Text="Brush Preview"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Button Content="Choose Brush Image"
                            Margin="0,0,0,10"
                            Click="OnChooseImage"/>

                    <Border BorderBrush="#CCC"
                            BorderThickness="1"
                            Background="#F8F8F8"
                            Height="200">

                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"/>
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1">

                <TextBlock Text="Brush Name"/>
                <TextBox x:Name="NameBox"
                         Margin="0,4,0,12"/>

                <TextBlock Text="Thickness"/>
                <Slider x:Name="SizeSlider"
                        Minimum="1"
                        Maximum="100"
                        Value="10"
                        Margin="0,4,0,12"/>

                <TextBlock Text="Opacity"/>
                <Slider x:Name="OpacitySlider"
                        Minimum="1"
                        Maximum="255"
                        Value="255"
                        Margin="0,4,0,12"/>

                <TextBlock Text="Spacing"/>
                <Slider x:Name="SpacingSlider"
                        Minimum="0.05"
                        Maximum="1"
                        Value="0.25"
                        Margin="0,4,0,0"/>

            </StackPanel>

        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="Cancel"
                    Width="90"
                    Height="32"
                    Margin="0,0,15,0"
                    Click="OnCancel"/>

            <Button Content="Save"
                    Width="90"
                    Height="32"
                    Click="OnSave"/>

        </StackPanel>

    </Grid>
</Window>