<Window x:Class="drawing_app.NewCanvasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:drawing_app"
        mc:Ignorable="d"
        Title="Create New Canvas" Height="180" Width="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
  
    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Width"/>
            <TextBox x:Name="WidthBox" Margin="0,4,0,10" Text="1100"/>

            <TextBlock Text="Height"/>
            <TextBox x:Name="HeightBox" Margin="0,4,0,0" Text="800"/>

        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">

            <Button Content="Cancel"
                    Width="70"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>

            <Button Content="Create"
                    Width="70"
                    Click="Create_Click"/>

        </StackPanel>

    </Grid>
</Window>
